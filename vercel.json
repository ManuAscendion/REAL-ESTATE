{
  "version": 2,
  "outputDirectory": ".",
  "functions": {
    "api/sheets.js": {
      "memory": 512,
      "maxDuration": 10
    }
  },
  "routes": [
    { "src": "/api/sheets", "dest": "/api/sheets.js" },
    { "src": "/ascendion-logo.png", "dest": "/ascendion-logo.png" },
    { "src": "/ss.png", "dest": "/ss.png" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}